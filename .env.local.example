# WebinarJam API credentials
# Get your API key from WebinarJam > Account > API
WEBINARJAM_API_KEY={api_key_here_later}

# Which webinar to register users for.
# NOTE: The provided task specified webinar_id "2", but that ID does not exist
# on the connected account. The only live webinar is ID "1". Set this to
# whichever webinar you want to target.
WEBINARJAM_WEBINAR_ID=1
